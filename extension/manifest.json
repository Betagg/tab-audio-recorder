{
  "manifest_version": 3,
  "name": "Tab Audio Recorder",
  "description": "Record audio from any browser tab and save it directly as MP3.",
  "version": "0.1.6",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "offscreen",
    "scripting",
    "tabCapture"
  ],
  "action": {
    "default_title": "Tab Audio Recorder",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start, pause, or resume tab audio recording"
    },
    "global-toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+8"
      },
      "description": "Start, pause, or resume tab audio recording from anywhere",
      "global": true
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
